# Copy this to .env.local and fill in values from your Vercel Postgres dashboard
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Set this to something secret — used to protect the admin results page
ADMIN_SECRET=your-secret-here
